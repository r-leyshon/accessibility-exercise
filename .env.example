# Google Cloud / Vertex AI
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=europe-west2

# Path to your service account key JSON file (for local development)
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account-key.json

# Vercel (for gallery page — only needed in production)
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=

# A11yDex / Neon (for /a11ydex score lookup — local testing)
# DATABASE_URL=your-neon-connection-string
# A11YDEX_DEBUG=1  # optional: enable logging in API and A11ydex page
